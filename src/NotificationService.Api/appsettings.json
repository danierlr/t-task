            "Enabled": true,
            "Priority": 200,
            "NumConcurrencySlots": 8,
            "BufferCapacity": 100,
            "SendTimeoutMs": 60000 // 1 min
          },
          "always_failing": {
            "Enabled": true,
            "Priority": 100,
            "NumConcurrencySlots": 8,
            "BufferCapacity": 100,
            "SendTimeoutMs": 60000 // 1 min
          }
        }
      },
