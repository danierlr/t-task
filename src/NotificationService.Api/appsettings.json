{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Pipeline": {
    "TotalNotificationCapacity": 1000,
    "ConfigurationUpdateTimeoutMs": 5000,
    "Channels": {
      "Sms": {
        "MaxNumRetries": 5,
        "ResultLingerDurationMs": 2000,
        "TimeToLiveMs": 2400000, // 40 min
        "InitialRetryDelayMs": 5000,
        "BackoffMultiplier": 1.8,
        "MaxRetryDelayMs": 420000, // 7 min
        "Providers": {
          "twilio": {
            "Enabled": true,
            "Priority": 400,
            "NumConcurrencySlots": 8,
            "BufferCapacity": 100,
            "SendTimeoutMs": 60000 // 1 min
          },
          "vonage": {
            "Enabled": true,
            "Priority": 300,
            "NumConcurrencySlots": 8,
            "BufferCapacity": 100,
            "SendTimeoutMs": 60000 // 1 min
          },
